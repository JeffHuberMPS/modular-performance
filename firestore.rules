rules_version = '2';

// ============================================================
//   MODULAR PERFORMANCE — FIRESTORE SECURITY RULES
//
//   Principle: users can ONLY read and write their own data.
//   No cross-user access. No unauthenticated access.
//   Developer accounts (role: 'developer') have no extra
//   Firestore permissions — billing_bypass is evaluated
//   client-side only.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────

    // Is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Is the requesting user the owner of this document?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // The owner's hardcoded developer account (full access by email).
    function isDevEmail() {
      return isAuth() && request.auth.token.email == 'jeffreyhuber86@gmail.com';
    }

    // On first-write (create), a normal user may ONLY self-provision safe,
    // non-paying defaults. Prevents anyone creating their own user doc with
    // billing_bypass:true / a paid tier / extra apps to unlock paid features
    // for free. Entitlement fields are otherwise written server-side (webhook).
    function safeNewUser() {
      let d = request.resource.data;
      return d.get('billing_bypass', false) == false
          && d.get('role', 'user') == 'user'
          && d.get('tier', 'single') == 'single'
          && d.get('apps', ['workout']) == ['workout'];
    }

    // Is the incoming data only updating allowed fields?
    // Prevents users from escalating their own role or tier.
    function noEscalation() {
      let disallowed = ['role', 'billing_bypass', 'stripe_customer_id',
                        'tier', 'apps', 'payment_failed', 'payment_grace_ends'];
      return !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(disallowed);
    }

    // ── User profiles ─────────────────────────────────────────
    match /users/{uid} {
      // Read: only the owner
      allow read: if isOwner(uid);

      // Create: only the owner, and only with safe non-paying defaults
      // (the dev account is exempt). Blocks self-granting paid entitlements.
      allow create: if isOwner(uid) && (isDevEmail() || safeNewUser());

      // Update: owner can update, but CANNOT change role, tier,
      // billing_bypass, stripe_customer_id, or apps.
      // Those fields are only written by our server-side webhook.
      allow update: if isOwner(uid) && noEscalation();

      // Delete: never (use support flow)
      allow delete: if false;

      // ── Workout sub-collections ────────────────────────────

      match /workout_history/{dateStr} {
        allow read, write: if isOwner(uid);
      }

      match /workout_prs/{exerciseName} {
        allow read, write: if isOwner(uid);
      }

      // ── Habit sub-collection ───────────────────────────────

      match /habit_logs/{dateStr} {
        allow read, write: if isOwner(uid);
      }

      // ── Sleep sub-collection ───────────────────────────────

      match /sleep_logs/{dateStr} {
        allow read, write: if isOwner(uid);
      }

      // ── Expense sub-collection ─────────────────────────────

      match /expense_logs/{dateStr} {
        allow read, write: if isOwner(uid);
      }

      // ── Journal sub-collection ─────────────────────────────

      match /journal_entries/{dateStr} {
        allow read, write: if isOwner(uid);
      }

      // ── Settings sub-document ──────────────────────────────

      match /settings/{settingDoc} {
        allow read, write: if isOwner(uid);
      }

      // ── Catch-all for the user's OWN tracker sub-collections ──
      // The trackers write to various sub-collections (sleep_entries, etc.) that
      // weren't all listed above — a denied write means data silently fails to save.
      // It's the user's own data under their own uid, so allow full read/write.
      // (The specific matches above stay for clarity; this just closes the gaps.)
      match /{coll}/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── CLOSED BETA (public, capped, self-serve) ──────────────
    //   Isolated from /users — does NOT touch customer or billing
    //   data. Powers the public beta link with a server-side cap.

    // The single counter doc: { count, cap, open }.
    match /beta_meta/{doc} {
      // Anyone may read the live spots-left count.
      allow read: if true;

      // Only the owner can create/seed, reset, or change the cap / open flag.
      allow write: if isDevEmail();

      // The public may increment the counter by EXACTLY ONE, never past the
      // cap, and may not touch the cap or the open flag. (This is what makes
      // the "100 free spots then closed" limit hold across every device.)
      allow update: if doc == 'counter'
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.count <= resource.data.cap
        && request.resource.data.cap == resource.data.cap
        && request.resource.data.open == resource.data.open;
    }

    // One doc per beta tester, keyed by an email-derived id.
    match /beta_signups/{key} {
      // A returning tester can fetch THEIR OWN record by exact id, but the
      // roster is NOT enumerable by the public (no email harvesting).
      allow get:  if true;
      allow list: if isDevEmail();          // only the owner sees the full list

      // Public self-serve join: allowed only while free spots remain, with a
      // fixed set of non-privileged fields.
      allow create: if
           get(/databases/$(database)/documents/beta_meta/counter).data.count
             < get(/databases/$(database)/documents/beta_meta/counter).data.cap
        && request.resource.data.email is string
        && request.resource.data.keys().hasOnly(
             ['name','email','joinedAt','betaStart','betaExpiry','invitedBy',
              'surveyCompleted','surveyDate','survey','lifetime','rating','bg']);

      // A tester may complete their survey (and thereby unlock lifetime), but
      // may only change survey-related fields — never their identity.
      allow update: if
           request.resource.data.email == resource.data.email
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['surveyCompleted','surveyDate','survey','lifetime','rating','bg']);

      // Owner can clean up; testers cannot delete.
      allow delete: if isDevEmail();
    }

    // ── Catch-all: deny everything else ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
