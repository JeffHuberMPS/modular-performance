rules_version = '2';

// ============================================================
//   MODULAR PERFORMANCE — FIRESTORE SECURITY RULES
//
//   Principle: users can ONLY read and write their own data.
//   No cross-user access. No unauthenticated access.
//   Developer accounts (role: 'developer') have no extra
//   Firestore permissions — billing_bypass is evaluated
//   client-side only.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────

    // Is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Is the requesting user the owner of this document?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // The owner's hardcoded developer account (full access by email).
    function isDevEmail() {
      return isAuth() && request.auth.token.email == 'jeffreyhuber86@gmail.com';
    }

    // On first-write (create), a normal user may ONLY self-provision safe,
    // non-paying defaults. Prevents anyone creating their own user doc with
    // billing_bypass:true / a paid tier / extra apps to unlock paid features
    // for free. Entitlement fields are otherwise written server-side (webhook).
    function safeNewUser() {
      let d = request.resource.data;
      return d.get('billing_bypass', false) == false
          && d.get('role', 'user') == 'user'
          && d.get('tier', 'single') == 'single'
          && d.get('apps', ['workout']) == ['workout'];
    }

    // Is the incoming data only updating allowed fields?
    // Prevents users from escalating their own role or tier.
    function noEscalation() {
      let disallowed = ['role', 'billing_bypass', 'stripe_customer_id',
                        'tier', 'apps', 'payment_failed', 'payment_grace_ends'];
      return !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(disallowed);
    }

    // ── User profiles ─────────────────────────────────────────
    match /users/{uid} {
      // Read: only the owner
      allow read: if isOwner(uid);

      // Create: only the owner, and only with safe non-paying defaults
      // (the dev account is exempt). Blocks self-granting paid entitlements.
      allow create: if isOwner(uid) && (isDevEmail() || safeNewUser());

      // Update: owner can update, but CANNOT change role, tier,
      // billing_bypass, stripe_customer_id, or apps.
      // Those fields are only written by our server-side webhook.
      allow update: if isOwner(uid) && noEscalation();

      // Delete: never (use support flow)
      allow delete: if false;

      // ── Workout sub-collections ────────────────────────────

      match /workout_history/{dateStr} {
        allow read, write: if isOwner(uid);
      }

      match /workout_prs/{exerciseName} {
        allow read, write: if isOwner(uid);
      }

      // ── Habit sub-collection ───────────────────────────────

      match /habit_logs/{dateStr} {
        allow read, write: if isOwner(uid);
      }

      // ── Sleep sub-collection ───────────────────────────────

      match /sleep_logs/{dateStr} {
        allow read, write: if isOwner(uid);
      }

      // ── Expense sub-collection ─────────────────────────────

      match /expense_logs/{dateStr} {
        allow read, write: if isOwner(uid);
      }

      // ── Journal sub-collection ─────────────────────────────

      match /journal_entries/{dateStr} {
        allow read, write: if isOwner(uid);
      }

      // ── Settings sub-document ──────────────────────────────

      match /settings/{settingDoc} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Catch-all: deny everything else ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
